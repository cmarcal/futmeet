{
  "name": "@futmeet/api",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "oxlint-node src/",
    "test": "vitest run --passWithNoTests",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:migrate": "node --env-file=.env --import tsx/esm node_modules/knex/bin/cli.js migrate:latest --knexfile knexfile.ts",
    "db:rollback": "node --env-file=.env --import tsx/esm node_modules/knex/bin/cli.js migrate:rollback --knexfile knexfile.ts",
    "db:reset": "node --env-file=.env --import tsx/esm node_modules/knex/bin/cli.js migrate:rollback --all --knexfile knexfile.ts && node --env-file=.env --import tsx/esm node_modules/knex/bin/cli.js migrate:latest --knexfile knexfile.ts",
    "db:seed": "node --env-file=.env --import tsx/esm node_modules/knex/bin/cli.js seed:run --knexfile knexfile.ts",
    "db:fresh": "npm run db:reset && npm run db:seed",
    "db:status": "node --env-file=.env --import tsx/esm node_modules/knex/bin/cli.js migrate:status --knexfile knexfile.ts",
    "docker:dev": "docker compose --profile dev up -d",
    "docker:deploy": "docker compose --profile deploy up -d",
    "docker:down": "docker compose --profile deploy down"
  },
  "dependencies": {
    "@fastify/cors": "^10",
    "@fastify/helmet": "^12.0.1",
    "@fastify/swagger": "^9",
    "@fastify/swagger-ui": "^5",
    "@futmeet/shared": "*",
    "ajv-formats": "^3.0.1",
    "fastify": "^5",
    "knex": "^3.1.0",
    "pg": "^8",
    "pino": "^9",
    "pino-pretty": "^13"
  },
  "devDependencies": {
    "@futmeet/oxlint-config": "*",
    "@futmeet/tsconfig": "*",
    "@types/pg": "^8",
    "oxlint": "^0.16.0",
    "tsx": "^4",
    "typescript": "^5",
    "vitest": "^2"
  }
}
